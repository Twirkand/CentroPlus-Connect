<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
    fx:controller="dam.mod.controllers.CambiarEmailController"
    spacing="15"
    prefWidth="390"
    prefHeight="844"
    style="-fx-padding: 15;">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="← Zurück" onAction="#volver" />
        <Label text="E-Mail ändern"
            style="-fx-font-size: 18px; -fx-font-weight: bold;" />
    </HBox>

    <Label fx:id="mensajeLabel"
        style="-fx-text-fill: red;" />

    <TextField fx:id="emailField" promptText="Neue E-Mail" />
    <TextField fx:id="repeatEmailField" promptText="E-Mail wiederholen" />

    <Button text="E-Mail aktualisieren"
        onAction="#cambiarEmail"
        prefWidth="250" />

</VBox>