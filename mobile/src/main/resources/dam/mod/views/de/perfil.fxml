<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<VBox xmlns:fx="http://javafx.com/fxml"
       fx:controller="dam.mod.controllers.PerfilController"
       spacing="15"
       prefWidth="390"
       prefHeight="844"
       style="-fx-padding: 15;">

       <HBox spacing="10" alignment="CENTER_LEFT">
              <Button text="← Zurück" onAction="#volver" />
              <Label text="Mein Profil"
                     style="-fx-font-size: 18px; -fx-font-weight: bold;" />
       </HBox>

       <VBox spacing="10">

              <Label text="Name"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblNombre"
                     style="-fx-font-size: 13px;" />

              <Label text="Ausweisnummer"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblDni"
                     style="-fx-font-size: 13px;" />

              <Label text="E-Mail"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblEmail"
                     style="-fx-font-size: 13px;" />

              <Label text="Telefon"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblTelefono"
                     style="-fx-font-size: 13px;" />

              <Label text="Benutzertyp"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblTipo"
                     style="-fx-font-size: 13px;" />

       </VBox>

       <VBox alignment="CENTER" spacing="10">
              <Button text="Passwort ändern"
                     onAction="#abrirCambiarPassword"
                     prefWidth="220" />

              <Button text="E-Mail ändern"
                     onAction="#abrirCambiarEmail"
                     prefWidth="220" />

              <Button text="Telefon ändern"
                     onAction="#abrirCambiarTelefono"
                     prefWidth="220" />

              <Button text="Abmelden"
                     onAction="#cerrarSesion"
                     prefWidth="220" />
       </VBox>

</VBox>