<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
    fx:controller="dam.mod.controllers.CambiarTelefonoController"
    spacing="15"
    prefWidth="390"
    prefHeight="844"
    style="-fx-padding: 15;">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="← Back" onAction="#volver" />
        <Label text="Change phone"
            style="-fx-font-size: 18px; -fx-font-weight: bold;" />
    </HBox>

    <Label fx:id="mensajeLabel"
        style="-fx-text-fill: red;" />

    <TextField fx:id="telefonoField" promptText="New phone number" />
    <TextField fx:id="repeatTelefonoField" promptText="Repeat phone number" />

    <Button text="Update phone"
        onAction="#cambiarTelefono"
        prefWidth="250" />

</VBox>