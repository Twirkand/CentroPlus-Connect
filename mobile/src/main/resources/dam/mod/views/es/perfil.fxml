<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<VBox xmlns:fx="http://javafx.com/fxml"
       fx:controller="dam.mod.controllers.PerfilController"
       spacing="15"
       prefWidth="390"
       prefHeight="844"
       style="-fx-padding: 15;">


       <HBox spacing="10" alignment="CENTER_LEFT">
              <Button text="← Volver" onAction="#volver" />
              <Label text="Mi perfil"
                     style="-fx-font-size: 18px; -fx-font-weight: bold;" />
       </HBox>


       <VBox spacing="10">

              <Label text="Nombre"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblNombre"
                     style="-fx-font-size: 13px;" />

              <Label text="DNI"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblDni"
                     style="-fx-font-size: 13px;" />

              <Label text="Email"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblEmail"
                     style="-fx-font-size: 13px;" />

              <Label text="Teléfono"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblTelefono"
                     style="-fx-font-size: 13px;" />

              <Label text="Tipo usuario"
                     style="-fx-font-size: 15px; -fx-font-weight: bold;" />
              <Label fx:id="lblTipo"
                     style="-fx-font-size: 13px;" />

       </VBox>


       <VBox alignment="CENTER" spacing="10">
              <Button text="Cambiar contraseña"
                     onAction="#abrirCambiarPassword"
                     prefWidth="220" />

              <Button text="Cambiar email"
                     onAction="#abrirCambiarEmail"
                     prefWidth="220" />

              <Button text="Cambiar teléfono"
                     onAction="#abrirCambiarTelefono"
                     prefWidth="220" />

              <Button text="Cerrar sesión"
                     onAction="#cerrarSesion"
                     prefWidth="220" />
       </VBox>

</VBox>